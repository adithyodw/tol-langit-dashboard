# ═══════════════════════════════════════════════════════════════════════════
# TOL LANGIT Dashboard - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Myfxbook API Configuration
MYFXBOOK_EMAIL=your-myfxbook-email@example.com
MYFXBOOK_PASSWORD=your-myfxbook-password
MYFXBOOK_API_URL=https://www.myfxbook.com/api

# MQL5 Signals API Configuration
MQL5_SIGNAL_ID=your-mql5-signal-id
MQL5_API_KEY=your-mql5-api-key

# Anthropic Claude API (for AI insights)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/tol_langit_db
SHADOW_DATABASE_URL=postgresql://username:password@localhost:5432/tol_langit_shadow

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development

# Vercel (for production)
VERCEL_ENV=development
VERCEL_GIT_COMMIT_SHA=
VERCEL_GIT_COMMIT_MESSAGE=

# Security
JWT_SECRET=your-jwt-secret-key-change-in-production
ENCRYPTION_KEY=your-encryption-key-for-storing-api-credentials

# Data Sync
DATA_SYNC_INTERVAL_MINUTES=5
ANALYTICS_CACHE_TTL_HOURS=24
PORTFOLIO_SNAPSHOT_INTERVAL_HOURS=1

# Logging
LOG_LEVEL=info
SENTRY_DSN=
